{
  "openapi": "3.1.0",
  "info": {
    "title": "Transcription Service",
    "version": "0.1.0"
  },
  "paths": {
    "/healthz": {
      "get": {
        "summary": "Healthz",
        "operationId": "healthz_healthz_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Healthz Healthz Get"
                }
              }
            }
          }
        }
      }
    },
    "/ops/loadtest": {
      "post": {
        "summary": "Loadtest",
        "description": "Burst-submit synthetic jobs so the System panel shows the semaphore\nworking the vendor cap live. Same insert-then-enqueue path as /transcribe;\nthe high-water mark is reset so the burst is measured from zero.",
        "operationId": "loadtest_ops_loadtest_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoadTestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoadTestResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ops": {
      "get": {
        "summary": "Ops",
        "operationId": "ops_ops_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OpsResponse"
                }
              }
            }
          }
        }
      }
    },
    "/transcribe": {
      "post": {
        "summary": "Submit Transcription",
        "operationId": "submit_transcription_transcribe_post",
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Idempotency-Key"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TranscribeRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscribeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcript/search": {
      "get": {
        "summary": "Search Transcripts",
        "operationId": "search_transcripts_transcript_search_get",
        "parameters": [
          {
            "name": "jobStatus",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Jobstatus"
            }
          },
          {
            "name": "userId",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Userid"
            }
          },
          {
            "name": "cursor",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Cursor"
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 100,
              "minimum": 1,
              "default": 20,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SearchResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcript/{job_id}": {
      "get": {
        "summary": "Get Transcript",
        "operationId": "get_transcript_transcript__job_id__get",
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid",
              "title": "Job Id"
            }
          },
          {
            "name": "view",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "View"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptResult"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ChunkInfo": {
        "properties": {
          "ordinal": {
            "type": "integer",
            "title": "Ordinal"
          },
          "audioPath": {
            "type": "string",
            "title": "Audiopath"
          },
          "status": {
            "type": "string",
            "title": "Status"
          },
          "attempts": {
            "type": "integer",
            "title": "Attempts"
          }
        },
        "type": "object",
        "required": [
          "ordinal",
          "audioPath",
          "status",
          "attempts"
        ],
        "title": "ChunkInfo"
      },
      "ChunkStats": {
        "properties": {
          "byStatus": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Bystatus"
          },
          "totalRetries": {
            "type": "integer",
            "title": "Totalretries"
          }
        },
        "type": "object",
        "required": [
          "byStatus",
          "totalRetries"
        ],
        "title": "ChunkStats"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "LatencyStats": {
        "properties": {
          "completedJobs": {
            "type": "integer",
            "title": "Completedjobs"
          },
          "p50Seconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "P50Seconds"
          },
          "p95Seconds": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "P95Seconds"
          }
        },
        "type": "object",
        "required": [
          "completedJobs",
          "p50Seconds",
          "p95Seconds"
        ],
        "title": "LatencyStats"
      },
      "LoadTestRequest": {
        "properties": {
          "jobs": {
            "type": "integer",
            "maximum": 100.0,
            "minimum": 1.0,
            "title": "Jobs",
            "default": 40
          },
          "chunks": {
            "type": "integer",
            "maximum": 8.0,
            "minimum": 1.0,
            "title": "Chunks",
            "default": 8
          }
        },
        "type": "object",
        "title": "LoadTestRequest"
      },
      "LoadTestResponse": {
        "properties": {
          "jobsSubmitted": {
            "type": "integer",
            "title": "Jobssubmitted"
          },
          "chunksSubmitted": {
            "type": "integer",
            "title": "Chunkssubmitted"
          }
        },
        "type": "object",
        "required": [
          "jobsSubmitted",
          "chunksSubmitted"
        ],
        "title": "LoadTestResponse"
      },
      "OpsResponse": {
        "properties": {
          "semaphore": {
            "$ref": "#/components/schemas/SemaphoreStats"
          },
          "queue": {
            "$ref": "#/components/schemas/QueueStats"
          },
          "jobs": {
            "additionalProperties": {
              "type": "integer"
            },
            "type": "object",
            "title": "Jobs"
          },
          "chunks": {
            "$ref": "#/components/schemas/ChunkStats"
          },
          "latency": {
            "$ref": "#/components/schemas/LatencyStats"
          }
        },
        "type": "object",
        "required": [
          "semaphore",
          "queue",
          "jobs",
          "chunks",
          "latency"
        ],
        "title": "OpsResponse"
      },
      "QueueStats": {
        "properties": {
          "depth": {
            "type": "integer",
            "title": "Depth"
          }
        },
        "type": "object",
        "required": [
          "depth"
        ],
        "title": "QueueStats"
      },
      "SearchResponse": {
        "properties": {
          "results": {
            "items": {
              "$ref": "#/components/schemas/TranscriptResult"
            },
            "type": "array",
            "title": "Results"
          },
          "nextCursor": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Nextcursor"
          }
        },
        "type": "object",
        "required": [
          "results"
        ],
        "title": "SearchResponse"
      },
      "SemaphoreStats": {
        "properties": {
          "held": {
            "type": "integer",
            "title": "Held"
          },
          "highWaterMark": {
            "type": "integer",
            "title": "Highwatermark"
          },
          "capacity": {
            "type": "integer",
            "title": "Capacity"
          }
        },
        "type": "object",
        "required": [
          "held",
          "highWaterMark",
          "capacity"
        ],
        "title": "SemaphoreStats"
      },
      "TranscribeRequest": {
        "properties": {
          "audioChunkPaths": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "maxItems": 64,
            "minItems": 1,
            "title": "Audiochunkpaths"
          },
          "userId": {
            "type": "string",
            "minLength": 1,
            "title": "Userid"
          }
        },
        "type": "object",
        "required": [
          "audioChunkPaths",
          "userId"
        ],
        "title": "TranscribeRequest"
      },
      "TranscribeResponse": {
        "properties": {
          "jobId": {
            "type": "string",
            "format": "uuid",
            "title": "Jobid"
          }
        },
        "type": "object",
        "required": [
          "jobId"
        ],
        "title": "TranscribeResponse"
      },
      "TranscriptResult": {
        "properties": {
          "jobId": {
            "type": "string",
            "format": "uuid",
            "title": "Jobid"
          },
          "userId": {
            "type": "string",
            "title": "Userid"
          },
          "transcriptText": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Transcripttext"
          },
          "chunkStatuses": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Chunkstatuses"
          },
          "chunks": {
            "items": {
              "$ref": "#/components/schemas/ChunkInfo"
            },
            "type": "array",
            "title": "Chunks"
          },
          "jobStatus": {
            "type": "string",
            "title": "Jobstatus"
          },
          "completedTime": {
            "anyOf": [
              {
                "type": "string",
                "format": "date-time"
              },
              {
                "type": "null"
              }
            ],
            "title": "Completedtime"
          }
        },
        "type": "object",
        "required": [
          "jobId",
          "userId",
          "transcriptText",
          "chunkStatuses",
          "chunks",
          "jobStatus",
          "completedTime"
        ],
        "title": "TranscriptResult"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  }
}