# Copy to .env to override compose defaults. All knobs, one place (§7):
# raising the vendor cap is literally ASR_MAX_CONCURRENCY=90 -> N.

# Global ASR concurrency budget (vendor cap 100; 10 held back as safety margin)
ASR_MAX_CONCURRENCY=90
# Permit lease TTL — must exceed ASR_TIMEOUT_SECONDS so a live call never loses its permit
ASR_LEASE_TTL_SECONDS=30
ASR_TIMEOUT_SECONDS=15

# Retry policy: full-jitter exponential backoff, uniform(0, min(MAX, BASE*2^(n-1)))
RETRY_MAX_ATTEMPTS=4
RETRY_BASE_DELAY=0.5
RETRY_MAX_DELAY=8

# Reconciler: stuck threshold must exceed lease TTL + max ASR call
CHUNK_STUCK_SECONDS=120
RECONCILER_INTERVAL_SECONDS=60

# Circuit breaker around the ASR client
BREAKER_WINDOW_SECONDS=30
BREAKER_MIN_REQUESTS=10
BREAKER_FAILURE_RATE_THRESHOLD=0.5
BREAKER_COOLDOWN_SECONDS=15
BREAKER_OPEN_DEFER_SECONDS=5

LOG_LEVEL=INFO
